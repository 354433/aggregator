{
    "output": "./output",
    "crawl": {
        "enable": true,
        "exclude": "付费|机场|收费|过期|无效",
        "threshold": 5,
        "singlelink": true,
        "github": {
            "enable": true,
            "pages": 2,
            "exclude": "付费|收费|机场|私人"
        },
        "telegram": {"enable": false},
        "twitter": {"enable": false},
        "pages": [{"enable": false}],
        "repositories": [{"enable": false}]
    },
    "filter": {"enable": true, "speed": 5000},
    "rename": {"enable": true},
    "liveness": {"enable": true}
}
